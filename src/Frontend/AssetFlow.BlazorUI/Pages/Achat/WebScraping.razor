@* ============================================================
   FICHIER  : Pages/Achat/WebScraping.razor
   RÔLE     : Page de recherche de prix marché (web scraping).
              Accessible depuis :
                - Le sidebar (recherche manuelle via champ texte)
                - Le bouton "Recherche de prix" dans DemandesAchat
                  (le nom du produit est passé via query string ?q=...)
   ============================================================ *@

@page "/achat/web-scraping"
@using Microsoft.JSInterop
@using AssetFlow.BlazorUI.Pages.Achat

<div class="ws-shell" data-theme="@_theme">

    @* ══════ OVERLAY SIDEBAR (mobile) ══════ *@
    @if (_sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    @* ══════ SIDEBAR — même structure que DemandesAchat ══════ *@
    <aside class="sidebar @(_sidebarOpen ? "open" : "")">

        @* Logo *@
        <div class="sidebar-header">
            <img src="images/logo.png" alt="AssetFlow" class="sidebar-logo-img" />
        </div>

        @* Navigation *@
        <nav class="sidebar-nav">
            <a href="/statistiques" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
                </span>
                <span class="nav-text">Statistiques</span>
            </a>
            <a href="/achat/materiel" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                </span>
                <span class="nav-text">Matériel</span>
            </a>
            <a href="/achat/fournisseurs" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </span>
                <span class="nav-text">Fournisseurs</span>
            </a>
            <a href="/demandes-achat" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </span>
                <span class="nav-text">Demande d'achat</span>
            </a>

            @* ── ACTIF : Scraping Marché ── *@
            <a href="/achat/web-scraping" class="nav-link active">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8" x2="11" y2="14"/>
                        <line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                </span>
                <span class="nav-text">Scraping Marché</span>
            </a>
        </nav>

        @* Profil utilisateur *@
        <div class="sidebar-profile">
            <div class="profile-avatar">@_initiales</div>
            <div class="profile-info">
                <p class="profile-name">@_nomUtilisateur</p>
                <p class="profile-role">@_roleUtilisateur</p>
            </div>
        </div>

        @* Support *@
        <div class="sidebar-support">
            <p class="support-label">SUPPORT IT</p>
            <p class="support-text">Besoin d'aide ?</p>
            <button class="support-btn">Contact</button>
        </div>
    </aside>

    @* ══════ ZONE PRINCIPALE ══════ *@
    <main class="ws-main">

        @* ── TOPBAR ── *@
        <header class="ws-topbar">
            <div class="ws-topbar-inner">
                @* Bouton menu hamburger (mobile) *@
                <button class="topbar-menu-btn" @onclick="ToggleSidebar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="3" y1="6"  x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>

                @* Titre de la page *@
                <div class="ws-topbar-brand">
                    <h1>Scraping Marché</h1>
                    <span class="ws-role-badge">Recherche de prix</span>
                </div>
            </div>
        </header>

        @* ── CONTENU PRINCIPAL ── *@
        <div class="ws-content">

            @* ── SECTION RECHERCHE ── *@
            <section class="ws-search-section">
                <div class="ws-search-header">
                    <div>
                        <h2 class="ws-section-title">Résultats du marché en temps réel</h2>
                        @if (_derniereRecherche != null)
                        {
                            <p class="ws-last-update">
                                <svg viewBox="0 0 24 24" width="14" height="14">
                                    <circle cx="12" cy="12" r="10"/>
                                    <polyline points="12 6 12 12 16 14"/>
                                </svg>
                                Dernière recherche : @_nomRecherche
                            </p>
                        }
                        else
                        {
                            <p class="ws-last-update">Saisissez un produit pour lancer la recherche</p>
                        }
                    </div>

                    @* Filtre Prix / Disponibilité *@
                    @if (_resultats.Any())
                    {
                        <div class="ws-segmented">
                            <button class="ws-seg-btn @(_filtreActif == "prix" ? "seg-active" : "")"
                                    @onclick='() => _filtreActif = "prix"'>
                                Prix
                            </button>
                            <button class="ws-seg-btn @(_filtreActif == "dispo" ? "seg-active" : "")"
                                    @onclick='() => _filtreActif = "dispo"'>
                                Disponibilité
                            </button>
                        </div>
                    }
                </div>

                @* ── BARRE DE RECHERCHE ── *@
                <div class="ws-search-bar">
                    <div class="ws-input-wrap">
                        <span class="ws-search-ico">
                            <svg viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="8"/>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                        </span>
                        <input class="ws-input"
                               type="text"
                               placeholder="Ex: Dell XPS 15, Souris Logitech, Switch Cisco…"
                               @bind="_recherche"
                               @bind:event="oninput"
                               @onkeydown="OnKeyDown" />
                        @if (!string.IsNullOrWhiteSpace(_recherche))
                        {
                            <button class="ws-clear-btn" @onclick="ViderRecherche" title="Effacer">
                                <svg viewBox="0 0 24 24">
                                    <line x1="18" y1="6" x2="6" y2="18"/>
                                    <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                            </button>
                        }
                    </div>
                    <button class="ws-search-btn"
                            disabled="@(string.IsNullOrWhiteSpace(_recherche) || _chargement)"
                            @onclick="LancerRecherche">
                        @if (_chargement)
                        {
                            <span class="ws-spinner"></span>
                            <span>Recherche…</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="8"/>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                            <span>Rechercher</span>
                        }
                    </button>
                </div>
            </section>

            @* ── ÉTAT INITIAL : pas encore de recherche ── *@
            @if (_derniereRecherche == null && !_chargement)
            {
                <div class="ws-empty-state">
                    <div class="ws-empty-ico">
                        <svg viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            <line x1="11" y1="8" x2="11" y2="14"/>
                            <line x1="8" y1="11" x2="14" y2="11"/>
                        </svg>
                    </div>
                    <h3>Recherche de prix en temps réel</h3>
                    <p>Saisissez le nom d'un produit pour comparer les prix<br />sur les principales marketplaces tunisiennes.</p>
                </div>
            }

            @* ── CHARGEMENT ── *@
            @if (_chargement)
            {
                <div class="ws-loading-state">
                    <div class="ws-loading-ring"></div>
                    <p>Recherche en cours sur les marketplaces…</p>
                    <small>Mytek · Tunisianet · Electrotounes · Wiki · SpaceNet</small>
                </div>
            }

            @* ── RÉSULTATS ── *@
            @if (_resultats.Any() && !_chargement)
            {
                var resultatsAffiches = _filtreActif == "dispo"
                    ? _resultats.Where(r => r.EnStock).ToList()
                    : _resultats.OrderBy(r => r.Prix).ToList();

                @* Cards top 3 *@
                <div class="ws-cards-grid">
                    @foreach (var r in resultatsAffiches.Take(3))
                    {
                        <div class="ws-card @(!r.EnStock ? "ws-card-rupture" : "")">
                            <div class="ws-card-top">
                                <div class="ws-store-ico">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                        <polyline points="9 22 9 12 15 12 15 22"/>
                                    </svg>
                                </div>
                                <span class="ws-badge @(r.EnStock ? "badge-stock" : "badge-rupture")">
                                    <span class="badge-dot"></span>
                                    @(r.EnStock ? "En stock" : "Rupture")
                                </span>
                            </div>
                            <p class="ws-card-site">@r.Site</p>
                            <h4 class="ws-card-produit">@r.NomProduit</h4>
                            <div class="ws-card-prix">
                                <span class="prix-val">@r.Prix.ToString("N3")</span>
                                <span class="prix-devise">DT</span>
                            </div>
                            <div class="ws-card-infos">
                                <div class="ws-card-info-row">
                                    <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                    <span>@(r.EnStock ? r.Livraison : "Indisponible")</span>
                                </div>
                                <div class="ws-card-info-row">
                                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    <span>@r.Garantie</span>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Url))
                            {
                                <a href="@r.Url" target="_blank" class="ws-card-btn">
                                    Voir sur le site
                                    <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </a>
                            }
                        </div>
                    }
                </div>

                @* Tableau complet *@
                <div class="ws-table-section">
                    <div class="ws-table-header">
                        <h3>Tous les résultats détaillés</h3>
                        <button class="ws-export-btn" @onclick="ExporterCsv">
                            <svg viewBox="0 0 24 24">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            Exporter CSV
                        </button>
                    </div>
                    <div class="ws-table-wrap">
                        <table class="ws-table">
                            <thead>
                                <tr>
                                    <th>Site</th>
                                    <th>Produit</th>
                                    <th>Prix</th>
                                    <th>Disponibilité</th>
                                    <th class="col-right">Lien</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in resultatsAffiches)
                                {
                                    <tr>
                                        <td class="td-site">@r.Site</td>
                                        <td class="td-produit">@r.NomProduit</td>
                                        <td class="td-prix">@r.Prix.ToString("N3") DT</td>
                                        <td>
                                            <span class="tbl-badge @(r.EnStock ? "badge-stock" : "badge-rupture")">
                                                @(r.EnStock ? "EN STOCK" : "RUPTURE")
                                            </span>
                                        </td>
                                        <td class="col-right">
                                            @if (!string.IsNullOrEmpty(r.Url))
                                            {
                                                <a href="@r.Url" target="_blank" class="tbl-link">Ouvrir</a>
                                            }
                                            else
                                            {
                                                <span class="tbl-link-off">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ── AUCUN RÉSULTAT après recherche ── *@
            @if (_derniereRecherche != null && !_resultats.Any() && !_chargement)
            {
                <div class="ws-empty-state">
                    <div class="ws-empty-ico ws-empty-warn">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    </div>
                    <h3>Aucun résultat trouvé</h3>
                    <p>Le produit « @_nomRecherche » n'a pas été trouvé<br />sur les marketplaces disponibles.</p>
                </div>
            }
        </div>
    </main>

    @* ══════ TOAST ══════ *@
    @if (!string.IsNullOrEmpty(_toastMsg))
    {
        <div class="ws-toast @_toastType">@_toastMsg</div>
    }
</div>
